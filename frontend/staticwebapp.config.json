{
  "routes": [
    {
      "route": "/signed-out.html",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/signed-out-full.html",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 403
    },
    "403": {
      "statusCode": 403
    }
  }
}
